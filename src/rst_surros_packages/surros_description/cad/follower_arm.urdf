      <geometry>
        <mesh filename="package://robot_description/mesh/link_2.stl">
        </mesh>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>
  
  <link name="link_3">
   <visual>
    <origin rpy="3.141592 0.0 0.0" xyz="0.100471 -0.002879 0.0"/>
      <geometry>
        <mesh filename="package://robot_description/mesh/link_3.stl">
        </mesh>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>
  
  <link name="link_4">
   <visual>
    <origin rpy="0 -1.5708 3.1416" xyz="0.0305 0.000007 0.001353"/>
      <geometry>
        <mesh filename="package://robot_description/mesh/link_4.stl">
        </mesh>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>
  
  <link name="link_5">
    <visual>
     <origin rpy="-1.5708 0.0 1.5708" xyz="0.0 0.0075 0.058"/>
      <geometry>
        <mesh filename="package://robot_description/mesh/link_5.stl">
        </mesh>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
