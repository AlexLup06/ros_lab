<?xml version="1.0"?>
<robot name="myfirst">

  <link name="base_link">
  <visual>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://robot_description/mesh/base_link.stl">
        </mesh>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link> 
  
  <link name="link_1">
   <visual>
    <origin rpy="3.141592 0.0 3.141592" xyz="0.0 0.0 0.0563"/>
      <geometry>
